{
  "name": "mcp-store",
  "version": "0.5.7",
  "description": "One-click MCP installer for AI clients",
  "main": "dist/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/aeolus9093/MCP_STORE.git"
  },
  "scripts": {
    "dev": "npx --yes concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "npx --yes wait-on http://localhost:5173 && tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:vite && npm run build:main",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:win": "npm run build && electron-builder --win --config electron-builder.config.js",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.config.js",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.config.js",
    "build:all": "npm run build && electron-builder --win --mac --linux --config electron-builder.config.js",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "collect": "tsc -p tsconfig.scripts.json && node dist-scripts/scripts/collect-mcps.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "electron",
    "installer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.2",
    "wait-on": "^7.2.0"
  }
}